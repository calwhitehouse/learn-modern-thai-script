# Project URL only (Settings → API → Project URL). NOT the REST URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# anon public key (starts with eyJ…). NOT service_role / sb_secret.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# hCaptcha site key (public). Secret key goes in Supabase → Auth → Bot and Abuse Protection.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-sitekey
